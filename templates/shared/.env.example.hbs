# Environment Variables — {{projectName}}
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Application ──────────────────────────────────────────────────────────────

NODE_ENV=development
{{#if (eq template "api")}}
PORT=3000
{{/if}}
{{#if (eq template "nextjs")}}
NEXT_PUBLIC_APP_URL=http://localhost:3000
{{/if}}
{{#if (eq template "react")}}
VITE_API_URL=http://localhost:3000
{{/if}}

# ─── Database ─────────────────────────────────────────────────────────────────

{{#if (eq database "postgres")}}
DATABASE_URL="postgresql://postgres:password@localhost:5432/{{projectName}}?schema=public"
{{/if}}
{{#if (eq database "mysql")}}
DATABASE_URL="mysql://root:password@localhost:3306/{{projectName}}"
{{/if}}
{{#if (eq database "sqlite")}}
DATABASE_URL="file:./dev.db"
{{/if}}

# ─── Authentication ───────────────────────────────────────────────────────────

{{#if (eq auth "nextauth")}}
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (uncomment and fill in as needed)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
{{/if}}
{{#if (eq auth "jwt")}}
# Generate with: openssl rand -base64 64
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET=""
REFRESH_TOKEN_EXPIRES_IN="30d"
{{/if}}

# ─── Deployment ───────────────────────────────────────────────────────────────

{{#if (eq deployment "vercel")}}
# Set automatically by Vercel — only needed for local testing
# VERCEL_URL=""
{{/if}}
{{#if (eq deployment "fly")}}
# Set via: fly secrets set KEY=VALUE
# FLY_API_TOKEN=""
{{/if}}
{{#if (eq deployment "railway")}}
# Set automatically by Railway
# RAILWAY_ENVIRONMENT=""
{{/if}}

# ─── Optional Integrations ────────────────────────────────────────────────────

# Logging (e.g. Axiom, Logtail)
# LOG_LEVEL=info
# AXIOM_TOKEN=""
# AXIOM_DATASET=""

# Error tracking (e.g. Sentry)
# SENTRY_DSN=""

# Email (e.g. Resend)
# RESEND_API_KEY=""

# File storage (e.g. S3)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
