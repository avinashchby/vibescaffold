{{#if (eq template "nextjs")}}
# ─── Stage 1: Dependencies ────────────────────────────────────────────────────
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app

COPY package.json {{#if (eq packageManager "npm")}}package-lock.json{{/if}}{{#if (eq packageManager "pnpm")}}pnpm-lock.yaml{{/if}}{{#if (eq packageManager "yarn")}}yarn.lock{{/if}}{{#if (eq packageManager "bun")}}bun.lockb{{/if}} ./
{{#if (eq packageManager "pnpm")}}
RUN corepack enable pnpm && pnpm install --frozen-lockfile
{{/if}}
{{#if (eq packageManager "yarn")}}
RUN corepack enable yarn && yarn install --immutable
{{/if}}
{{#if (eq packageManager "npm")}}
RUN npm ci
{{/if}}
{{#if (eq packageManager "bun")}}
RUN npm install -g bun && bun install --frozen-lockfile
{{/if}}

# ─── Stage 2: Builder ─────────────────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

{{#if (neq database "none")}}
# Generate Prisma client
RUN {{#if (eq packageManager "npm")}}npx{{/if}}{{#if (eq packageManager "pnpm")}}pnpm exec{{/if}}{{#if (eq packageManager "yarn")}}yarn{{/if}}{{#if (eq packageManager "bun")}}bunx{{/if}} prisma generate
{{/if}}

ENV NEXT_TELEMETRY_DISABLED=1

RUN {{#if (eq packageManager "npm")}}npm run build{{/if}}{{#if (eq packageManager "pnpm")}}pnpm build{{/if}}{{#if (eq packageManager "yarn")}}yarn build{{/if}}{{#if (eq packageManager "bun")}}bun run build{{/if}}

# ─── Stage 3: Runner ──────────────────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
{{/if}}

