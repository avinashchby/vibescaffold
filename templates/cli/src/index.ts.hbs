/**
 * Return a greeting string for the given name.
 *
 * @param name - The name to greet.
 * @returns A greeting string.
 */
export function hello(name: string): string {
  if (!name.trim()) {
    throw new Error("name must not be blank");
  }
  return `Hello, ${name}!`;
}
